#:import utils kivy.utils

WindowManager:
    Pantalla1:
    Pantalla2:
    Pantalla3:
    Pantalla4:
    Pantalla_prueba:

# etiqueta personalizada con fondo de color
<BackgroundColorLabel@Label>:
    background_color: 0,0,0,0
    size_hint: None, 0.5
    #size: self.texture_size
    width: self.texture_size[0]

    canvas.before:
        Color:
            rgba: self.background_color
        Rectangle:
            size: self.size
            pos: self.pos

# creemos una subclase para un botón redondeado
<RoundedButton@Button>:
    background_color: (0,0,0,0)
    background_normal: ''
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#cc9227")
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [30]  # Ajusta el valor para redondear más o menos las esquinas

<Pantalla_prueba>:
    name: "pantalla_prueba"
    background_normal: ''
    background_color: utils.get_color_from_hex("#39b1f7")

    BoxLayout:
        orientation: "vertical"
        size: root.size

        padding: 50
        spacing: 20

        Label:
            markup: True
            text: "Pantalla de prueba"
            font_size : 25
            color: "#2b072b"

        Button:
            text: "Botón de prueba"
            color: "#9bffff"
            background_color: utils.get_color_from_hex("#062569")
            background_normal: ''
            pos_hint: {"center_x": 0.5}
            size_hint: (0.5, 0.5)
            on_press:
                app.saludar()

        RoundedButton:
            text: "Botón redondeado"
            pos_hint: {"center_x": 0.5}
            size_hint: (0.5, 0.5)
            color: "#850000"
            on_press: print("¡Botón redondeado presionado!")

        CheckBox:
            size_hint: None, None
            size: "48dp", "48dp"
            pos_hint: {"center_x": 0.5}

        Slider:
            id: slider
            min: 0
            max: 100
            step: 1
            orientation: 'horizontal'

        Label:
            text: str(slider.value)

        Switch:
            id: switch
        Label:
            text: ' :) ' if switch.active else ' :( '

<Pantalla1>:
    name: "main"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'stars.jpg'

    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'
            
        GridLayout:
            cols:1

            Label:
                markup: True
                text: "¡Bienvenido/a!"
                font_size : 20
                color: "#e2d0e2"

            BoxLayout:
                orientation: "horizontal"
                padding: 50
                spacing: 20 

                Button:
                    id: btn_inicio
                    text: "Comenzar"
                    font_size: "18"
                    size: (150,100)
                    size_hint: None, 0.25
                    color: "#06a8c9"
                    on_release:
                        app.root.current = "pantalla2"
                        root.manager.transition.direction = "right"

                Button:
                    id: btn_inicio
                    text: "Iniciar sesión"
                    font_size: "18"
                    size: (150,100)
                    size_hint: None, 0.25
                    color: "#06a8c9"
                    on_release:
                        app.root.current = "pantalla4"
                        root.manager.transition.direction = "down"

<Pantalla2>:
    name: "pantalla2"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'stars2.jpg'

    GridLayout:
        cols: 1

        Label:
            markup: True
            text: "Esta será tu primera misión:"
            font_size : 18
            color: "#785ab9"

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BackgroundColorLabel:
                text: "Etiqueta personalizada con texto muuuuy largo"
                color: "#e01be0"
                background_color: utils.get_color_from_hex("#350669")

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_move2
                text: "Siguiente pantalla"
                font_size: "18"
                size_hint : 0.25, 0.25
                color: "#55d32f"
                on_release:
                    app.root.current = "pantalla3"
                    root.manager.transition.direction = "right"

<Pantalla3>:

    name: "pantalla3"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'dinos1.jpg'

    GridLayout:
        cols: 1

        BackgroundColorLabel:
            pos_hint: None, 0.5
            text: "Esta es la tercera pantalla"
            font_size : 18
            color: "#151020"
            background_color: utils.get_color_from_hex("#96bbfc")

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BoxLayout:
                orientation: "horizontal"
                padding: 50
                spacing: 20 
            
                Button:
                    id: btn_move_inicio
                    text: "Regresar pantalla"
                    font_size: "18"
                    size_hint : 0.25, 0.25
                    color: "#55d32f"
                    on_release:
                        app.root.current = "pantalla2"
                        root.manager.transition.direction = "left"
                
                Button:
                    id: btn_move_inicio2
                    text: "Reiniciar"
                    font_size: "18"
                    size_hint : 0.25, 0.25
                    color: "#55d32f"
                    on_release:
                        app.root.current = "main"
                        root.manager.transition.direction = "right"
            

<Pantalla4>:
    name: "pantalla4"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'grid.jpg'

    GridLayout:
        cols: 1

        Label:
            markup: True
            text: "Contraseña"
            font_size : 24
            color: "#d9641b"

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            
            TextInput:
                text: "Introduce la contraseña"
                size_hint: 0.5,0.5
                multiline: True
                password: False
                font_size: 25
        
        BoxLayout:
            orientation: "horizontal"
            padding: 50
            spacing: 20 
        
            Button:
                id: btn_move_inicio
                text: "Intentar"
                font_size: "18"
                color: "#d36e2f"
                on_release:
                    app.root.current = "pantalla2"
                    root.manager.transition.direction = "left"
            
            Button:
                id: btn_move_inicio2
                text: "Reiniciar"
                font_size: "18"
                color: "#55d32f"
                on_release:
                    app.root.current = "main"
                    root.manager.transition.direction = "right"