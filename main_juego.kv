#:import utils kivy.utils
#:import FadeTransition kivy.uix.screenmanager.FadeTransition
#:import FallOutTransition kivy.uix.screenmanager.FallOutTransition

WindowManager:
    transition: FadeTransition()
    duration: 0.30
    Pantalla1:
    Pantalla2:
    Pantalla3:
    Pantalla_password:
    Pantalla_error:
    Fade:

<Fade>:
    name: "fade"

    Button:
        id: btn_fade
        text: "ver opacidad"
        font_size: "18"
        size: (150,100)
        size_hint: None, 0.25
        color: "#06a8c9"
        on_press: root.fade(btn_fade)


# etiqueta personalizada con fondo de color
<BackgroundColorLabel@Label>:
    background_color: 0,0,0,0
    size_hint: None, 0.5
    #size: self.texture_size
    width: self.texture_size[0]
    height: self.texture_size[1] + 50

    canvas.before:
        Color:
            rgba: self.background_color
        Rectangle:
            size: self.size
            pos: self.pos

# creemos una subclase para un botón redondeado
<RoundedButton@Button>:
    background_color: (0,0,0,0)
    background_normal: ''
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#cc9227")
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [30]  # Ajusta el valor para redondear más o menos las esquinas

<Pantalla1>:
    name: "main"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/stars.jpg'

    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'top'

        Label:
            id: label_bienv
            markup: True
            text: "¡Bienvenido/a!"
            font_size : 40
            bold: True
            color: "#e2d0e2"

    AnchorLayout:
        anchor_x: 'center'

        BoxLayout:
            orientation: "horizontal"
            padding: 50
            spacing: 20
            size_hint_x: None
            width: self.minimum_width

            Button:
                id: btn_inicio
                text: "Comenzar aventura"
                font_size: "18"
                size: (170,100)
                size_hint: None, 0.25
                color: "#06a8c9"
                on_release:
                    app.root.current = "pantalla2"
                    root.manager.transition.direction = "right"

            Button:
                id: btn_inicio
                text: "Iniciar sesión"
                font_size: "18"
                size: (150,100)
                size_hint: None, 0.25
                color: "#06a8c9"
                on_release:
                    app.root.current = "pantalla_password"
                    root.manager.transition.direction = "down"
            
            Button:
                id: press_anim
                text: "Click me!"
                size: (150,100)
                size_hint: None, 0.25
                background_color: utils.get_color_from_hex("#dc3cf160")
                color: 1,1,1,1
                on_press: root.animate_it(label_bienv)

<Pantalla2>:
    name: "pantalla2"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/stars2.jpg'

    GridLayout:
        cols: 1

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BackgroundColorLabel:
                id: label_mision
                text: "Esta será tu primera misión:\nPresiona el botón 5 veces"
                font_size : 18
                color: "#e01be0"
                background_color: utils.get_color_from_hex("#350669")

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_contar
                text: "Click"
                font_size: "18"
                size_hint : 0.25, 0.25
                color: "#55d32f"
                on_press: root.clicks()

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_move2
                text: "Siguiente pantalla"
                font_size: "18"
                size_hint : 0.25, 0.25
                color: "#55d32f"
                on_release:
                    app.root.current = "pantalla3"
                    root.manager.transition.direction = "right"

<Pantalla3>:

    name: "pantalla3"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/dinos1.jpg'

    GridLayout:
        cols: 1

        AnchorLayout:
            anchor_x: 'center'
            BackgroundColorLabel:
                pos_hint: None, 0.5
                text: "¡Excelente! Pasemos a la siguiente misión"
                font_size : 18
                color: "#151020"
                background_color: utils.get_color_from_hex("#96bbfca9")

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BoxLayout:
                orientation: "horizontal"
                padding: 50
                spacing: 20

                Button:
                    id: btn_move_inicio
                    text: "Regresar pantalla"
                    font_size: "18"
                    size_hint : 0.25, 0.25
                    color: "#55d32f"
                    on_release:
                        app.root.current = "pantalla2"
                        root.manager.transition.direction = "left"
                
                Button:
                    id: btn_move_inicio2
                    text: "Reiniciar"
                    font_size: "18"
                    size_hint : 0.25, 0.25
                    color: "#55d32f"
                    on_release:
                        app.root.current = "main"
                        root.manager.transition.direction = "right"
            

<Pantalla_password>:
    name: "pantalla_password"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/grid.jpg'

    GridLayout:
        cols: 1

        Label:
            id: label_password
            markup: True
            text: "Ingresa la contraseña: "
            font_size : 24
            color: "#d9641b"

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            TextInput:
                id: input_password
                text: ""
                size_hint: 0.5,0.5
                multiline: True
                password: False
                font_size: 25

        BoxLayout:
            orientation: "horizontal"
            padding: 50
            spacing: 20

            Button:
                id: btn_move_inicio
                text: "Intentar"
                font_size: "18"
                color: "#d36e2f"
                on_press:
                    root.check_password(label_password, input_password)
                    input_password.text = ""
                #on_release:
                 #   app.root.current = "pantalla2"
                  #  root.manager.transition.direction = "left"
       
            Button:
                id: btn_move_inicio2
                text: "Reiniciar"
                font_size: "18"
                color: "#55d32f"
                on_release:
                    app.root.current = "main"
                    root.manager.transition.direction = "right"

<Pantalla_error@Screen>:
    name: "pantalla_error"

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#a10a0a")
        Rectangle:
            size: self.size
            pos: self.pos
    BoxLayout:
        orientation : "vertical"
        padding:50
        spacing:20
    
        AnchorLayout:
            anchor_x: "center"
            Label:
                text: "ERROR\nEspera para intentarlo otra vez"
                color: utils.get_color_from_hex("#ffffff")
                font_size: 40
                bold: True

        AnchorLayout:
            anchor_x: "center"
            Button:
                id: btn_move_inicio2
                text: "Reiniciar"
                font_size: "18"
                size_hint: 0.25,0.25
                color: "#55d32f"
                on_release:
                    app.root.current = "main"
                    root.manager.transition.direction = "right"
