#:import utils kivy.utils
#:import FadeTransition kivy.uix.screenmanager.FadeTransition
#:import FallOutTransition kivy.uix.screenmanager.FallOutTransition
#:import Factory kivy.factory.Factory

WindowManager:
    transition: FadeTransition()
    duration: 0.30
    #GameScreen:
    MenuScreen:
    Pantalla1:
    Pantalla2:
    Pantalla3:
    Pantalla_password:
    Pantalla_error:
    MediaScreen:
    VideoScreen:

# Pop Up de inventario

<MyPopup@Popup>:
    auto_dismiss: True
    title: "Mi PopUp"
    size_hint: 0.5,0.5
    Label:
        text: "Hola"

<SoundButton@Button>:
    on_press: root.play.sound("MEDIA/sparkle.mp3")

# etiqueta personalizada con fondo de color
<BackgroundColorLabel@Label>:
    background_color: 0,0,0,0
    size_hint: None, 0.5
    #size: self.texture_size
    width: self.texture_size[0]
    height: self.texture_size[1] + 50

    canvas.before:
        Color:
            rgba: self.background_color
        Rectangle:
            size: self.size
            pos: self.pos

# creemos una subclase para un botón redondeado
<RoundedButton@Button>:
    background_color: (0,0,0,0)
    background_normal: ''
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#cc9227")
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [30]  # Ajusta el valor para redondear más o menos las esquinas

<GameScreen>:
    name: "pantalla_juego"
    background_color: utils.get_color_from_hex("#8766d3")
    background_normal: ''

    on_enter: app.colocar_trinkets(self.ids.container, app.lista_trinkets)

    FloatLayout:
        id: container
        Label:
            text: "Prueba"


# Pantalla de menú

<MenuScreen@Screen>:
    name: "menu"
    background_color: utils.get_color_from_hex("#8766d3")
    background_normal: ''

    GridLayout:
        rows:2
        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            Label:
                text: "Menú"
                font_name: "MiFuente"
                font_size: 40
                bold: True
                color: utils.get_color_from_hex("#77007e")
                size_hint: None, 0.5

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BoxLayout:
                orientation : "horizontal"
                padding: 40
                spacing: 10

                Button:
                    id: btn_menu_main
                    text: "Pop Up"
                    bold: True
                    color: "#9bffff"
                    background_color: utils.get_color_from_hex("#5480df")
                    background_normal: ''
                    size_hint: None, None
                    size: (self.texture_size[0] + 20, self.texture_size[1] + 20)
                    on_release:
                        app.root.current = "main"
                        root.manager.transition.direction = "down"

                Button:
                    id: btn_menu_media
                    text: "Multimedia"
                    bold: True
                    color: "#9bffff"
                    background_color: utils.get_color_from_hex("#5480df")
                    background_normal: ''
                    size_hint: None, None
                    size: (self.texture_size[0] + 20, self.texture_size[1] + 20)
                    on_release:
                        app.root.current = "media_screen"
                        root.manager.transition.direction = "down"

                Button:
                    id: btn_menu_video
                    text: "Reproductor de video"
                    bold: True
                    color: "#9bffff"
                    background_color: utils.get_color_from_hex("#5480df")
                    background_normal: ''
                    size_hint: None, None
                    size: (self.texture_size[0] + 20, self.texture_size[1] + 20)
                    on_release:
                        app.root.current = "video_screen"
                        root.manager.transition.direction = "down"
                
                Button:
                    id: btn_popup
                    text: "Pop Up"
                    bold: True
                    color: "#9bffff"
                    background_color: utils.get_color_from_hex("#5480df")
                    background_normal: ''
                    size_hint: None, None
                    size: (self.texture_size[0] + 20, self.texture_size[1] + 20)
                    on_release: Factory.MyPopup().open()

<Pantalla1>:
    name: "main"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/stars.jpg'

    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'top'

        Label:
            id: label_bienv
            markup: True
            text: "¡Bienvenido/a!"
            font_size : 40
            bold: True
            color: "#e2d0e2"

    AnchorLayout:
        anchor_x: 'center'

        BoxLayout:
            orientation: "horizontal"
            padding: 50
            spacing: 20
            size_hint_x: None
            width: self.minimum_width

            Button:
                id: btn_inicio
                text: "Comenzar aventura"
                font_size: "18"
                size: (170,100)
                size_hint: None, 0.25
                color: "#06a8c9"
                on_release:
                    app.root.current = "pantalla2"
                    root.manager.transition.direction = "right"

            SoundButton:
                id: btn_inicio
                text: "Iniciar sesión"
                font_size: "18"
                size: (150,100)
                size_hint: None, 0.25
                color: "#06a8c9"
                on_release:
                    app.root.current = "pantalla_password"
                    root.manager.transition.direction = "down"

            Button:
                id: press_anim
                text: "Click me!"
                size: (150,100)
                size_hint: None, 0.25
                background_color: utils.get_color_from_hex("#dc3cf160")
                color: 1,1,1,1
                on_press: root.animate_it(label_bienv)

<Pantalla2>:
    name: "pantalla2"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/stars2.jpg'

    GridLayout:
        cols: 1

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BackgroundColorLabel:
                id: label_mision
                text: "Esta será tu primera misión:\nPresiona el botón 5 veces"
                font_size : 18
                color: "#e01be0"
                background_color: utils.get_color_from_hex("#350669")

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_contar
                text: "Click"
                font_size: "18"
                size_hint : 0.25, 0.25
                color: "#55d32f"
                on_press: root.clicks()

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            SoundButton:
                id: btn_move2
                text: "Siguiente pantalla"
                font_size: "18"
                size_hint : 0.25, 0.25
                color: "#55d32f"
                on_release:
                    app.root.current = "pantalla3"
                    root.manager.transition.direction = "right"

<Pantalla3>:

    name: "pantalla3"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/dinos1.jpg'

    GridLayout:
        cols: 1

        AnchorLayout:
            anchor_x: 'center'
            BackgroundColorLabel:
                pos_hint: None, 0.5
                size_hint: None, None
                size: (self.texture_size[0] + 10, self.texture_size[1] + 10)
                text: "¡Excelente! Pasemos a la siguiente misión"
                font_size : 18
                color: "#151020"
                background_color: utils.get_color_from_hex("#96bbfca9")

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BoxLayout:
                orientation: "horizontal"
                padding: 50
                spacing: 20

                Button:
                    id: btn_move_inicio
                    text: "Regresar pantalla"
                    font_size: "18"
                    size_hint : 0.25, 0.25
                    color: "#55d32f"
                    on_release:
                        app.root.current = "pantalla2"
                        root.manager.transition.direction = "left"

                Button:
                    id: btn_move_inicio2
                    text: "Reiniciar"
                    font_size: "18"
                    size_hint : 0.25, 0.25
                    color: "#55d32f"
                    on_release:
                        app.root.current = "main"
                        root.manager.transition.direction = "right"


<Pantalla_password>:
    name: "pantalla_password"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/grid.jpg'

    GridLayout:
        cols: 1

        Label:
            id: label_password
            markup: True
            text: "Ingresa la contraseña: "
            font_size : 24
            color: "#d9641b"

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            TextInput:
                id: input_password
                text: ""
                size_hint: 0.5,0.5
                multiline: False
                password: False
                font_size: 25

        BoxLayout:
            orientation: "horizontal"
            padding: 50
            spacing: 20

            Button:
                id: btn_move_inicio
                text: "Intentar"
                font_size: "18"
                color: "#d36e2f"
                on_press:
                    root.check_password(label_password, input_password)
                    input_password.text = ""

            Button:
                id: btn_move_inicio2
                text: "Reiniciar"
                font_size: "18"
                color: "#55d32f"
                on_release:
                    app.root.current = "main"
                    root.manager.transition.direction = "right"

<Pantalla_error@Screen>:

    name: "pantalla_error"

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#a10a0a")
        Rectangle:
            size: self.size
            pos: self.pos
    BoxLayout:
        orientation : "vertical"
        padding:50
        spacing:20

        AnchorLayout:
            anchor_x: "center"
            Label:
                text: "ERROR\nEspera para intentarlo otra vez"
                color: utils.get_color_from_hex("#ffffff")
                font_size: 40
                bold: True

        AnchorLayout:
            anchor_x: "center"
            Button:
                id: btn_move_inicio2
                text: "Reiniciar"
                font_size: "18"
                size_hint: 0.25,0.25
                color: "#55d32f"
                on_release:
                    app.root.current = "main"
                    root.manager.transition.direction = "right"

# pantalla con GIFS y efectos de sonido en botones
<MediaScreen>:

    name: "media_screen"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'MEDIA/grid.jpg'

    BoxLayout:
        orientation: "vertical"
        padding:50
        spacing:15

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'top'

            Label:
                markup: True
                text: "Pantalla multimedia"
                font_size : 25
                font_name: "MiFuente"
                bold: True
                color: "#833b83"

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Image:
                source: "MEDIA/gifplanet.gif"
                anim_delay: 0.1
                size_hint: None, None
                size: 300,300

        BoxLayout:
            orientation: "horizontal"
            padding: 20
            spacing: 20

            Button:
                id: btn_efectos
                text: "Click me!!"
                size_hint: 0.25,0.25
                on_press: root.play_sound("MEDIA/sparkle_sound.mp3")

            ToggleButton:
                id: btn_musica
                #text: "⏯"
                text: "REANUDAR MÚSICA" if self.state == 'down' else "PAUSAR MÚSICA"
                size_hint: 0.25,0.25
                #size: 100,50
                color: utils.get_color_from_hex("#000000")
                background_color: utils.get_color_from_hex("#aecc27")
                background_normal: ''
                on_press: app.toggle_musica()


<VideoScreen>:
    name: "video_screen"
    background_color: utils.get_color_from_hex("#71ffac")
    background_normal: ''

    BoxLayout:
        orientation: "horizontal"
        padding: 10
        spacing: 10

        Label:
            markup: True
            text: "Pantalla para video"
            font_size: 25
            size_hint_y: 0.15
            font_name: "MiFuente"
            bold: True
            color: "#833b83"
        
        AnchorLayout:
            anchor_x: 'right'
            anchor_y: 'bottom'

            ToggleButton:
                id: btn_musica
                #text: "⏯"
                text: "REANUDAR MÚSICA" if self.state == 'down' else "PAUSAR MÚSICA"
                size_hint_y: 0.15
                size: 150,50
                color: utils.get_color_from_hex("#000000")
                background_color: utils.get_color_from_hex("#aecc27")
                background_normal: ''
                on_press: app.toggle_musica()

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            size_hint_y: 0.7

            Video:
                source: "MEDIA/video_tortuga.mp4"
                state: "play"
                options: {"eos": "loop"}
                allow_stretch: True
                keep_ratio: False
             

        